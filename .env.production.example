# Production env template — Next.js loads .env.production / .env.production.local
# (the latter gitignored). Copy this file to .env.production.local in production
# environments and fill in the secrets; or wire each variable through the
# platform (Cloud Run, Vercel, etc.) so secrets never touch git.

# === Environment ===
NODE_ENV=production

# === Backend ===
# Required. Real backend URL (https only in production).
BACKEND_API_URL=https://api.example.com

# === Mock mode ===
# Must be '0' in production. Mock dispatch is a dev/test aid only.
USE_MOCK=0

# === Session (iron-session cookie, see ADR 005 v2) ===
# Required always (>= 32 chars). Generate with:
#   openssl rand -base64 48
SESSION_SECRET=
# Optional. Previous SESSION_SECRET kept verify-only during rotation. Keep set
# until SESSION_TTL_SECONDS passes after rotating SESSION_SECRET, then remove.
SESSION_SECRET_PREVIOUS=
SESSION_COOKIE_NAME=streamsight_session
# 30d, aligned with refresh token lifetime (ADR 004)
SESSION_TTL_SECONDS=2592000

# === Redis (BFF session store + refresh lock, see ADR 006) ===
# Required. Discrete host/port/password — REDIS_TLS_ENABLED=1 wraps the
# connection in TLS for managed providers (ElastiCache, Upstash) that
# require it.
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=replace-me
REDIS_KEY_PREFIX=streamsight-bff-prod
REDIS_TLS_ENABLED=1
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=1000

# === CSRF ===
# Production MUST contain at least one non-localhost origin (config.ts guards this).
ALLOWED_ORIGINS=https://www.example.com,https://example.com

# === Health / observability ===
# CI/CD should overwrite these per release.
APP_VERSION=0.0.0
APP_COMMIT=

# === Public ===
NEXT_PUBLIC_APP_NAME=StreamSight
