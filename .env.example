# === Environment ===
NODE_ENV=development

# === Backend ===
# Required when USE_MOCK=0. BFF → backend base URL.
BACKEND_API_URL=http://localhost:3001

# === Mock mode ===
# '1' to bypass real backend (handled by src/lib/mock/dispatch.ts).
USE_MOCK=1

# === Session (iron-session cookie, see ADR 005 v2) ===
# Required (>= 32 chars) — iron-session signs every cookie, so this must be set
# even in USE_MOCK=1 mode. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=
# Optional. Previous SESSION_SECRET kept verify-only during a rotation window.
# iron-session is fed [current, previous] so old cookies still decrypt while new
# ones get signed with the current secret. Remove after the rotation completes.
SESSION_SECRET_PREVIOUS=
SESSION_COOKIE_NAME=streamsight_session
# Default 30d, aligned with the refresh token lifetime (ADR 004). Users only need
# to re-login after 30 days of inactivity, instead of being kicked out earlier
# when the cookie expires but the refresh token is still valid.
SESSION_TTL_SECONDS=2592000

# === Redis (BFF session store + refresh lock, see ADR 006) ===
# Required when USE_MOCK=0. Local dev: `docker compose up -d redis` from infra/
# (infra/docker-compose.yml maps host 6379, matching infra/.env).
# Discrete host/port/password — passwords with URL-unsafe characters don't
# need percent-encoding (symmetric with backend's spec 001 §3.3).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=streamsight-bff-dev
REDIS_TLS_ENABLED=0
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=1000

# === CSRF ===
# Comma-separated allowed origins. Production must contain non-localhost.
ALLOWED_ORIGINS=http://localhost:3000

# === Health / observability ===
APP_VERSION=0.0.0
APP_COMMIT=

# === Public ===
NEXT_PUBLIC_APP_NAME=StreamSight
