{
  "family": "streamsight-frontend",
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/streamsight_ecs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "streamsight-frontend",
      "image": "REPLACE_ON_DEPLOY",
      "essential": true,
      "portMappings": [
        {
          "name": "web",
          "containerPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        { "name": "NEXT_TELEMETRY_DISABLED", "value": "1" },

        { "name": "BACKEND_API_URL", "value": "http://api:3001" },

        { "name": "USE_MOCK", "value": "0" },

        { "name": "SESSION_COOKIE_NAME", "value": "streamsight_session" },
        { "name": "SESSION_TTL_SECONDS", "value": "2592000" },

        { "name": "REDIS_HOST", "value": "REPLACE_EC2_PRIVATE_IP" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "REDIS_KEY_PREFIX", "value": "streamsight-bff-prod" },
        { "name": "REDIS_TLS_ENABLED", "value": "0" },
        { "name": "REDIS_CONNECT_TIMEOUT_MS", "value": "2000" },
        { "name": "REDIS_COMMAND_TIMEOUT_MS", "value": "1000" },

        { "name": "ALLOWED_ORIGINS", "value": "http://streamsight-alb-public-1132378971.ap-southeast-2.elb.amazonaws.com,https://d1cony3w0kn08c.cloudfront.net" },

        { "name": "NEXT_PUBLIC_APP_NAME", "value": "StreamSight" }
      ],
      "secrets": [
        {
          "name": "SESSION_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:streamsight_vm_pg_redis_1:SESSION_SECRET::"
        },
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:streamsight_vm_pg_redis_1:REDIS_PASSWORD::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/streamsight-frontend",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
