{
  "family": "jko-frontend",
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/jko_ecs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "containerDefinitions": [
    {
      "name": "jko-frontend",
      "image": "REPLACE_ON_DEPLOY",
      "essential": true,
      "portMappings": [
        {
          "name": "web",
          "containerPort": 3000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "HOSTNAME", "value": "0.0.0.0" },
        { "name": "NEXT_TELEMETRY_DISABLED", "value": "1" },

        { "name": "BACKEND_API_URL", "value": "http://api:3001" },

        { "name": "USE_MOCK", "value": "0" },
        { "name": "ENABLE_DEV_LOGIN", "value": "0" },

        { "name": "SESSION_COOKIE_NAME", "value": "jko_session" },
        { "name": "SESSION_TTL_SECONDS", "value": "2592000" },

        { "name": "REDIS_KEY_PREFIX", "value": "jko-bff-prod" },
        { "name": "REDIS_TLS_ENABLED", "value": "0" },
        { "name": "REDIS_CONNECT_TIMEOUT_MS", "value": "2000" },
        { "name": "REDIS_COMMAND_TIMEOUT_MS", "value": "1000" },

        { "name": "ALLOWED_ORIGINS", "value": "REPLACE_ALLOWED_ORIGINS" },

        { "name": "NEXT_PUBLIC_APP_NAME", "value": "JKODonation" }
      ],
      "secrets": [
        {
          "name": "SESSION_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:SESSION_SECRET::"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:BFF_REDIS_URL::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/jko-frontend",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
